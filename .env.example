NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info

DATABASE_URL=postgres://shoditsa_app:shoditsa_dev@localhost:5434/shoditsa
DATABASE_POOL_MAX=10
POSTGRES_PASSWORD=change_me

BETTER_AUTH_SECRET=generate_at_least_32_random_bytes
BETTER_AUTH_URL=http://localhost:3001
TRUSTED_ORIGINS=http://localhost:5173,http://localhost:3001
COOKIE_SECURE=false

SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=dev@shoditsa.local
AUTH_EMAIL_ENABLED=true
AUTH_YANDEX_ENABLED=false
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

ADMIN_EMAILS=breneize@yandex.ru
ADMIN_USER_IDS=00000000-0000-4000-8000-000000000000
PROMO_CODE_PEPPER=generate_at_least_32_random_bytes
MEDIA_ROOT=./.tmp/media
PUBLIC_MEDIA_BASE_URL=/media
LEGACY_IMPORT_ENABLED=true
LEGACY_IMPORT_TICKET_CAP=500

SENTRY_DSN=
APP_VERSION=0.1.0
GIT_SHA=dev
METRICS_TOKEN=generate_random_monitoring_token

ENRICHMENT_DATA_ROOT=./data/enrichment-agent
WORKER_ID=local-worker
WORKER_POLL_INTERVAL_MS=2000
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_STALE_AFTER_MS=60000
MUSIC_PIPELINE_MODEL=gpt-5-mini
# Optional dedicated root key for API credentials saved from the admin UI.
# When omitted, the server derives a separate encryption key from BETTER_AUTH_SECRET.
PIPELINE_SECRETS_KEY=

VITE_API_BASE_URL=/api/v1
VITE_AUTH_BASE_URL=/api/auth
VITE_APP_VERSION=0.1.0
VITE_YANDEX_GAMES=false

# Upstream content pipeline only; never expose as VITE_*.
KINOPOISK_API_KEY=
OPENAI_API_KEY=
LASTFM_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
THEAUDIODB_API_KEY=
MUSICBRAINZ_USER_AGENT=shoditsa-music/1.0 (admin@example.com)
