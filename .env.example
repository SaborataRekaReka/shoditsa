# Ключи используются только локальными Node-скриптами. Не добавляйте их в клиентский код.
KINOPOISK_API_KEY=your_key_here

# Обязателен для discovery, веб-проверки и генерации музыкальных подсказок.
OPENAI_API_KEY=your_openai_key_here

# Необязательные источники, повышающие покрытие музыкальных метаданных.
LASTFM_API_KEY=your_lastfm_key_here
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
THEAUDIODB_API_KEY=your_theaudiodb_key_here
