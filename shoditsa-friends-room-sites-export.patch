+  const [roundIndex, setRoundIndex] = useState(0)
+  const [timeLeft, setTimeLeft] = useState(30)
+  const [countdown, setCountdown] = useState(3)
+  const [answer, setAnswer] = useState('')
+  const [submitted, setSubmitted] = useState(false)
+  const [players, setPlayers] = useState<Player[]>(INITIAL_PLAYERS)
+  const [copied, setCopied] = useState(false)
+  const [chat, setChat] = useState(['Дима: это будет сложно 😅', 'Аня: ставлю на фантастику', 'Макс: уже есть идеи 💡'])
+  const [message, setMessage] = useState('')
+  const mode = MODES.find((entry) => entry.id === modeId) ?? MODES[0]
+  const round = mode.rounds[roundIndex % mode.rounds.length]
+
+  useEffect(() => {
+    if (phase !== 'countdown') return
+    if (countdown <= 0) {
+      setPhase('active')
+      setTimeLeft(answerTime)
+      return
+    }
+    const timer = window.setTimeout(() => setCountdown((value) => value - 1), 700)
+    return () => window.clearTimeout(timer)
+  }, [answerTime, countdown, phase])
+
+  useEffect(() => {
+    if (phase !== 'active' || timeLeft <= 0) return
+    const timer = window.setInterval(() => setTimeLeft((value) => Math.max(0, value - 1)), 1000)
+    return () => window.clearInterval(timer)
+  }, [phase, timeLeft])
+
+  useEffect(() => {
+    if (phase === 'active' && timeLeft === 0) revealResults()
+  }, [phase, timeLeft])
+
+  const rankedPlayers = useMemo(() => [...players].sort((a, b) => b.score - a.score), [players])
+  const answeredCount = players.filter((player) => player.answer).length
+
+  const copyInvite = async () => {
+    const invite = `${window.location.origin}/games/together?room=K3L7P`
+    await navigator.clipboard?.writeText(invite)
+    setCopied(true)
+    window.setTimeout(() => setCopied(false), 1600)
+  }
+
+  const startGame = () => {
+    setRoundIndex(0)
+    setPlayers(INITIAL_PLAYERS.map((player) => ({ ...player, answer: undefined, correct: undefined, delta: undefined })))
+    setAnswer('')
+    setSubmitted(false)
+    setCountdown(3)
+    setPhase('countdown')
+  }
+
+  const submitAnswer = (event?: FormEvent) => {
+    event?.preventDefault()
+    if (!answer.trim() || submitted || phase !== 'active') return
+    setSubmitted(true)
+    setPlayers((current) => current.map((player) => player.isYou ? { ...player, answer: answer.trim() } : player))
+  }
+
+  const revealResults = () => {
+    const simulated = fakeAnswers(round, roundIndex)
+    setPlayers((current) => current.map((player, index) => {
+      const submittedAnswer = player.isYou ? player.answer ?? answer.trim() : simulated[Math.max(0, index - 1)]
+      const correct = Boolean(submittedAnswer) && isCorrect(submittedAnswer, round)
+      const delta = correct ? Math.max(200, 1000 - index * 120) : 0
+      return { ...player, answer: submittedAnswer || 'Нет ответа', correct, delta, score: player.score + delta }
+    }))
+    setPhase('results')
+  }
+
+  const nextRound = () => {
+    if (roundIndex + 1 >= roundsTotal) {
+      setPhase('finished')
+      return
+    }
+    setRoundIndex((value) => value + 1)
+    setPlayers((current) => current.map((player) => ({ ...player, answer: undefined, correct: undefined, delta: undefined })))
+    setAnswer('')
+    setSubmitted(false)
+    setCountdown(3)
+    setPhase('countdown')
+  }
+
+  const sendMessage = (event: FormEvent) => {
+    event.preventDefault()
+    if (!message.trim()) return
+    setChat((current) => [...current, `Вы: ${message.trim()}`])
+    setMessage('')
+  }
+
+  return <div className="friends-room-page" style={{ '--room-accent': mode.color } as CSSProperties}>
+    <AppHeader {...navigation} />
+    <main className="friends-room">
+      <header className="friends-room__utility">
+        <button type="button" onClick={onExit}><ArrowLeft /> Выйти из комнаты</button>
+        <span><Crown /> Открытый предпросмотр</span>
+      </header>
+
+      {phase === 'lobby'
+        ? <Lobby
+            mode={mode}
+            players={players}
+            roundsTotal={roundsTotal}
+            answerTime={answerTime}
+            copied={copied}
+            onMode={setModeId}
+            onRounds={setRoundsTotal}
+            onTime={setAnswerTime}
+            onCopy={copyInvite}
+            onStart={startGame}
+          />
+        : phase === 'finished'
+          ? <FinalScreen players={rankedPlayers} onAgain={startGame} onLobby={() => setPhase('lobby')} onExit={onExit} />
+          : <div className="friends-room__columns">
+              <LeftRail
+                round={roundIndex + 1}
+                roundsTotal={roundsTotal}
+                timeLeft={timeLeft}
+                answered={answeredCount}
+                players={players.length}
+                copied={copied}
+                chat={chat}
+                message={message}
+                onCopy={copyInvite}
+                onMessage={setMessage}
+                onSend={sendMessage}
+              />
+              <section className="friends-room__stage">
+                {phase === 'countdown'
+                  ? <div className="room-countdown" aria-live="polite"><span>Раунд {roundIndex + 1}</span><strong>{Math.max(1, countdown)}</strong><p>Приготовьтесь</p></div>
+                  : <GameTicket
+                      mode={mode}
+                      round={round}
+                      roundNumber={roundIndex + 1}
+                      answer={answer}
+                      submitted={submitted}
+                      phase={phase}
+                      players={players}
+                      onAnswer={setAnswer}
+                      onSubmit={submitAnswer}
+                      onReveal={revealResults}
+                      onNext={nextRound}
+                    />}
+                <ActivityLog phase={phase} round={roundIndex + 1} players={players} />
+              </section>
+              <RightRail players={rankedPlayers} phase={phase} />
+            </div>}
+    </main>
+  </div>
+}
+
+function Lobby({ mode, players, roundsTotal, answerTime, copied, onMode, onRounds, onTime, onCopy, onStart }: {
+  mode: Mode; players: Player[]; roundsTotal: 3 | 5 | 7; answerTime: 15 | 20 | 30 | 45; copied: boolean
+  onMode: (mode: ModeId) => void; onRounds: (value: 3 | 5 | 7) => void; onTime: (value: 15 | 20 | 30 | 45) => void
+  onCopy: () => void; onStart: () => void
+}) {
+  return <section className="room-lobby">
+    <div className="room-lobby__intro">
+      <span className="room-kicker">Игра с друзьями · тестовый показ</span>
+      <h1>Соберите свою<br />игровую комнату</h1>
+      <p>Выберите тему и правила. После запуска все участники одновременно увидят подсказки и отправят по одному ответу.</p>
+      <div className="room-code-card"><span>Код комнаты</span><strong>K3L7P</strong><button type="button" onClick={onCopy}>{copied ? <Check /> : <Copy />}{copied ? 'Скопировано' : 'Копировать ссылку'}</button></div>
+      <div className="room-lobby__people">
+        {players.map((player) => <span key={player.id} style={{ '--avatar': player.color } as CSSProperties}>{player.initials}</span>)}
+        <small>{players.length} игроков в комнате</small>
+      </div>
+    </div>
+    <div className="room-lobby__settings">
+      <div className="room-settings-heading"><span>Настройки сеанса</span><strong>{mode.label}</strong></div>
+      <fieldset className="room-mode-picker">
+        <legend>Категория</legend>
+        <div>{MODES.map((entry) => <button key={entry.id} type="button" className={entry.id === mode.id ? 'is-active' : ''} style={{ '--mode-color': entry.color } as CSSProperties} onClick={() => onMode(entry.id)}><img src={publicAssetUrl(entry.poster)} alt="" /><span>{entry.label}</span>{entry.id === mode.id && <CheckCircle2 />}</button>)}</div>
+      </fieldset>
+      <div className="room-rule-grid">
+        <fieldset><legend>Раундов</legend><div>{([3, 5, 7] as const).map((value) => <button type="button" className={roundsTotal === value ? 'is-active' : ''} key={value} onClick={() => onRounds(value)}>{value}</button>)}</div></fieldset>
+        <fieldset><legend>Время на ответ</legend><div>{([15, 20, 30, 45] as const).map((value) => <button type="button" className={answerTime === value ? 'is-active' : ''} key={value} onClick={() => onTime(value)}>{value} сек</button>)}</div></fieldset>
+      </div>
+      <button className="room-start" type="button" onClick={onStart}><Play /> Начать игру <span>{roundsTotal} раундов · {answerTime} сек</span></button>
+    </div>
+  </section>
+}
+
+function LeftRail({ round, roundsTotal, timeLeft, answered, players, copied, chat, message, onCopy, onMessage, onSend }: {
+  round: number; roundsTotal: number; timeLeft: number; answered: number; players: number; copied: boolean; chat: string[]; message: string
+  onCopy: () => void; onMessage: (value: string) => void; onSend: (event: FormEvent) => void
+}) {
+  return <aside className="room-left-rail">
+    <section className="room-panel room-panel--code"><span>Комната</span><strong>K3L7P</strong><small><Users /> {players} игроков</small><button type="button" onClick={onCopy}><Share2 /> {copied ? 'Ссылка скопирована' : 'Пригласить друзей'}</button></section>
+    <section className="room-panel room-progress"><span>Прогресс игры</span><div><strong>Раунд {round} из {roundsTotal}</strong><small><Clock3 /> {String(Math.floor(timeLeft / 60)).padStart(2, '0')}:{String(timeLeft % 60).padStart(2, '0')}</small><small><CheckCircle2 /> Ответили {answered} / {players}</small></div></section>
+    <section className="room-panel room-chat"><span>Чат комнаты</span><div>{chat.slice(-5).map((entry, index) => <p key={`${entry}-${index}`}>{entry}</p>)}</div><form onSubmit={onSend}><input value={message} onChange={(event) => onMessage(event.target.value)} placeholder="Сообщение…" aria-label="Сообщение в чат" /><button type="submit" aria-label="Отправить"><Send /></button></form></section>
+  </aside>
+}
+
+function GameTicket({ mode, round, roundNumber, answer, submitted, phase, players, onAnswer, onSubmit, onReveal, onNext }: {
+  mode: Mode; round: Mode['rounds'][number]; roundNumber: number; answer: string; submitted: boolean; phase: Phase; players: Player[]
+  onAnswer: (value: string) => void; onSubmit: (event?: FormEvent) => void; onReveal: () => void; onNext: () => void
+}) {
+  const suggestions = [round.answer, ...(round.aliases ?? [])].filter((entry) => normalize(entry).includes(normalize(answer)) && normalize(answer).length > 1)
+  return <article className={`room-ticket ${phase === 'results' ? 'is-results' : ''}`}>
+    <div className="room-ticket__stub"><img src={publicAssetUrl(mode.poster)} alt="" /><span>Вход<br /><strong>один</strong></span><small>№ {String(roundNumber).padStart(3, '0')}</small></div>
+    <div className="room-ticket__body">
+      <div className="room-ticket__meta">Игра с друзьями · Раунд №{String(roundNumber).padStart(3, '0')}</div>
+      <h1>{mode.label}</h1>
+      {phase === 'results'
+        ? <div className="room-reveal"><span>Правильный ответ</span><h2>{round.answer}</h2><p>{players.filter((player) => player.correct).length} из {players.length} игроков ответили правильно</p><button type="button" onClick={onNext}>Следующий раунд <Play /></button></div>
+        : <>
+            <div className="room-ticket__question"><span>Задание</span><h2>{mode.prompt}</h2></div>
+            <div className="room-hints">{round.hints.map((hint) => <span key={hint}>{hint}</span>)}</div>
+            <form className={`room-answer ${submitted ? 'is-submitted' : ''}`} onSubmit={onSubmit}>
+              {submitted ? <div><CheckCircle2 /><span><small>Ответ принят</small><strong>{answer}</strong></span></div> : <><input autoFocus value={answer} onChange={(event) => onAnswer(event.target.value)} placeholder={`Введите ${mode.id === 'city' ? 'город' : 'название'}…`} aria-label="Ваш ответ" /><button type="submit" disabled={!answer.trim()}>Отправить</button></>}
+              {!submitted && suggestions.length > 0 && <div className="room-answer__suggestions">{suggestions.map((suggestion) => <button type="button" key={suggestion} onClick={() => onAnswer(suggestion)}>{suggestion}</button>)}</div>}
+            </form>
+            <div className="room-ticket__foot"><span>Можно отправить только один вариант</span><button type="button" onClick={onReveal}>Показать результаты</button></div>
+          </>}
+    </div>
+  </article>
+}
+
+function RightRail({ players, phase }: { players: Player[]; phase: Phase }) {
+  return <aside className="room-right-rail">
+    <section className="room-panel room-players"><span>Игроки ({players.length})</span><div>{players.map((player, index) => <article key={player.id}><i style={{ '--avatar': player.color } as CSSProperties}>{player.initials}</i><strong>{player.name}{player.isYou ? ' (вы)' : ''}</strong>{index === 0 && <Crown />}<small>{formatScore(player.score)}</small></article>)}</div></section>
+    <section className="room-panel room-answers"><span>Ответы раунда</span>{phase === 'results' ? <div>{players.map((player) => <article key={player.id}><i style={{ '--avatar': player.color } as CSSProperties}>{player.initials}</i><span><strong>{player.name}</strong><small>{player.answer}</small></span>{player.correct ? <CheckCircle2 /> : <XCircle />}</article>)}</div> : <div className="room-waiting"><MessageCircle /><p>Ответы откроются после завершения раунда</p></div>}</section>
+    {phase === 'results' && <section className="room-panel room-podium"><span>Счёт за раунд</span><div>{players.slice(0, 3).map((player, index) => <article key={player.id} className={`place-${index + 1}`}><strong>{index + 1}</strong><small>+{player.delta ?? 0}</small></article>)}</div></section>}
+  </aside>
+}
+
+function ActivityLog({ phase, round, players }: { phase: Phase; round: number; players: Player[] }) {
+  return <section className="room-activity"><span>Ход игры</span><article><i><Play /></i><div><strong>Раунд {round} начался</strong><small>Угадайте ответ по подсказкам</small></div><time>сейчас</time></article>{players.filter((player) => player.answer).slice(0, 3).map((player) => <article key={player.id}><i>{phase === 'results' ? player.correct ? <Check /> : <X /> : <Check />}</i><div><strong>{player.name} {phase === 'results' ? player.correct ? 'дал правильный ответ' : 'ошибся' : 'отправил ответ'}</strong>{phase === 'results' && <small>+{player.delta ?? 0} очков</small>}</div><time>сейчас</time></article>)}</section>
+}
+
+function FinalScreen({ players, onAgain, onLobby, onExit }: { players: Player[]; onAgain: () => void; onLobby: () => void; onExit: () => void }) {
+  const winner = players[0]
+  return <section className="room-final">
+    <div className="room-final__ticket"><span>Сеанс завершён</span><Trophy /><small>Победитель</small><h1>{winner.name}</h1><strong>{formatScore(winner.score)} очков</strong><div>{players.slice(0, 3).map((player, index) => <article key={player.id}><i>{index + 1}</i><span>{player.name}</span><strong>{formatScore(player.score)}</strong></article>)}</div><button type="button" onClick={onAgain}><RotateCcw /> Сыграть ещё раз</button><button type="button" onClick={onLobby}><Gamepad2 /> Сменить категорию</button><button type="button" onClick={onExit}><LogOut /> Выйти</button></div>
+  </section>
+}
