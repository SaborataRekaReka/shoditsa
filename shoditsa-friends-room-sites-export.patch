@@ -0,0 +1,240 @@
+.friends-room-page {
+  --room-paper: #eee7d8;
+  --room-paper-2: #e2d8c5;
+  --room-ink: #171a17;
+  min-height: 100vh;
+  color: #f2ecdf;
+  background:
+    radial-gradient(circle at 50% 24%, color-mix(in srgb, var(--room-accent) 8%, transparent), transparent 36%),
+    repeating-linear-gradient(90deg, rgba(255,255,255,.012) 0, rgba(255,255,255,.012) 1px, transparent 1px, transparent 5px),
+    #111411;
+}
+
+.friends-room { width: min(1480px, calc(100% - 40px)); margin: 0 auto; padding: 20px 0 80px; }
+.friends-room__utility { min-height: 44px; margin: 0 0 14px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
+.friends-room__utility button { min-height: 40px; padding: 0 14px; border: 1px solid var(--color-line-strong); border-radius: 10px; color: var(--color-muted); background: rgba(20,23,20,.76); display: inline-flex; align-items: center; gap: 8px; font: 600 12px Manrope, sans-serif; cursor: pointer; }
+.friends-room__utility button:hover { color: var(--color-text); border-color: var(--color-muted); }
+.friends-room__utility button svg { width: 15px; }
+.friends-room__utility > span { color: color-mix(in srgb, var(--room-accent) 72%, #fff); display: inline-flex; align-items: center; gap: 7px; font-size: 10px; font-weight: 800; letter-spacing: .13em; text-transform: uppercase; }
+.friends-room__utility > span svg { width: 14px; }
+
+.room-panel { border: 1px solid rgba(239,231,215,.13); border-radius: 12px; background: linear-gradient(150deg, rgba(31,35,31,.92), rgba(22,25,22,.92)); box-shadow: 0 14px 40px rgba(0,0,0,.16); }
+.room-panel > span, .room-activity > span { color: #aaa395; font-size: 10px; font-weight: 800; letter-spacing: .17em; text-transform: uppercase; }
+
+/* Lobby */
+.room-lobby { min-height: 690px; border: 1px solid rgba(239,231,215,.14); border-radius: 20px; overflow: hidden; display: grid; grid-template-columns: .88fr 1.12fr; background: rgba(20,23,20,.85); box-shadow: 0 30px 90px rgba(0,0,0,.25); }
+.room-lobby__intro { position: relative; overflow: hidden; padding: clamp(46px, 6vw, 86px); background: var(--room-paper); color: var(--room-ink); }
+.room-lobby__intro::before { content: ''; position: absolute; inset: 0; opacity: .12; pointer-events: none; background: url('/images/realistic-grain-paper-texture.webp') center/cover; mix-blend-mode: multiply; }
+.room-lobby__intro::after { content: ''; position: absolute; right: -12px; top: 0; width: 24px; height: 100%; background: radial-gradient(circle at center, #111411 0 8px, transparent 9px) center top/24px 48px repeat-y; }
+.room-lobby__intro > * { position: relative; z-index: 1; }
+.room-kicker { color: #3b7f52; font-size: 11px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
+.room-lobby__intro h1 { max-width: 620px; margin: 25px 0 22px; font: 500 clamp(50px, 6vw, 82px)/.94 Oswald, sans-serif; letter-spacing: -.035em; text-transform: uppercase; }
+.room-lobby__intro > p { max-width: 540px; margin: 0; color: #665f53; font-size: 13px; line-height: 1.75; }
+.room-code-card { width: min(390px, 100%); margin-top: 42px; padding: 18px 20px; border: 1px solid rgba(23,26,23,.18); border-radius: 12px; display: grid; grid-template-columns: 1fr auto; gap: 3px 18px; }
+.room-code-card > span { color: #746c5e; font-size: 9px; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; }
+.room-code-card > strong { grid-row: 1 / 3; grid-column: 1; font: 500 35px/1 Oswald, sans-serif; letter-spacing: .08em; }
+.room-code-card button { grid-row: 1 / 3; grid-column: 2; align-self: center; border: 0; color: #2e6c44; background: transparent; display: inline-flex; align-items: center; gap: 7px; font: 700 10px Manrope, sans-serif; cursor: pointer; }
+.room-code-card button svg { width: 15px; }
+.room-lobby__people { margin-top: 28px; display: flex; align-items: center; }
+.room-lobby__people > span { width: 31px; height: 31px; margin-left: -7px; border: 2px solid var(--room-paper); border-radius: 50%; color: #111; background: var(--avatar); display: grid; place-items: center; font-size: 9px; font-weight: 900; }
+.room-lobby__people > span:first-child { margin-left: 0; }
+.room-lobby__people small { margin-left: 10px; color: #746c5e; font-size: 10px; }
+.room-lobby__settings { padding: clamp(36px, 5vw, 70px); display: flex; flex-direction: column; }
+.room-settings-heading { padding-bottom: 25px; border-bottom: 1px dashed rgba(239,231,215,.16); display: flex; justify-content: space-between; align-items: baseline; }
+.room-settings-heading span { color: #aaa395; font-size: 10px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
+.room-settings-heading strong { color: var(--room-accent); font: 500 27px Oswald, sans-serif; text-transform: uppercase; }
+.room-lobby fieldset { min-width: 0; margin: 28px 0 0; padding: 0; border: 0; }
+.room-lobby legend { margin-bottom: 13px; color: #aaa395; font-size: 9px; font-weight: 800; letter-spacing: .16em; text-transform: uppercase; }
+.room-mode-picker > div { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 9px; }
+.room-mode-picker button { position: relative; min-width: 0; height: 105px; padding: 0; overflow: hidden; border: 1px solid rgba(239,231,215,.13); border-radius: 11px; color: #f2ecdf; background: #181b18; cursor: pointer; }
+.room-mode-picker button::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 10%, rgba(10,12,10,.9)); }
+.room-mode-picker img { width: 100%; height: 100%; object-fit: cover; opacity: .48; filter: saturate(.75); transition: opacity .2s, transform .25s; }
+.room-mode-picker button:hover img, .room-mode-picker button.is-active img { opacity: .75; transform: scale(1.035); }
+.room-mode-picker button.is-active { border-color: var(--mode-color); box-shadow: inset 0 -3px 0 var(--mode-color); }
+.room-mode-picker button span { position: absolute; z-index: 2; left: 10px; bottom: 9px; font: 500 17px Oswald, sans-serif; text-transform: uppercase; }
+.room-mode-picker button svg { position: absolute; z-index: 2; right: 8px; top: 8px; width: 15px; color: var(--mode-color); }
+.room-rule-grid { display: grid; grid-template-columns: .8fr 1.2fr; gap: 28px; }
+.room-rule-grid fieldset > div { padding: 4px; border: 1px solid rgba(239,231,215,.13); border-radius: 10px; display: flex; }
+.room-rule-grid button { flex: 1; min-height: 39px; padding: 0 8px; border: 0; border-radius: 7px; color: #aaa395; background: transparent; font: 700 10px Manrope, sans-serif; cursor: pointer; }
+.room-rule-grid button.is-active { color: #152017; background: var(--room-accent); }
+.room-start { min-height: 57px; margin-top: auto; padding: 0 20px; border: 0; border-radius: 11px; color: #132117; background: var(--room-accent); display: flex; align-items: center; justify-content: center; gap: 9px; font: 800 12px Manrope, sans-serif; letter-spacing: .05em; text-transform: uppercase; cursor: pointer; box-shadow: 0 12px 24px color-mix(in srgb, var(--room-accent) 18%, transparent); }
+.room-start svg { width: 17px; fill: currentColor; }
+.room-start span { margin-left: auto; opacity: .65; font-size: 9px; }
+
+/* Active room */
+.friends-room__columns { display: grid; grid-template-columns: 250px minmax(520px, 1fr) 280px; gap: 16px; align-items: start; }
+.room-left-rail, .room-right-rail { display: grid; gap: 14px; }
+.room-panel--code, .room-progress, .room-chat, .room-players, .room-answers, .room-podium { padding: 18px; }
+.room-panel--code > strong { margin: 9px 0 2px; display: block; font: 500 32px Oswald, sans-serif; letter-spacing: .08em; }
+.room-panel--code > small { color: #aaa395; display: flex; align-items: center; gap: 6px; font-size: 10px; }
+.room-panel--code > small svg { width: 13px; }
+.room-panel--code button { width: 100%; min-height: 44px; margin-top: 18px; border: 0; border-radius: 9px; color: #183120; background: var(--room-accent); display: flex; align-items: center; justify-content: center; gap: 8px; font: 800 9px Manrope, sans-serif; letter-spacing: .08em; text-transform: uppercase; cursor: pointer; }
+.room-panel--code button svg { width: 14px; }
+.room-progress > div { margin-top: 14px; padding: 13px; border: 1px solid rgba(239,231,215,.13); border-radius: 9px; display: grid; gap: 12px; }
+.room-progress strong { color: var(--room-accent); font-size: 11px; }
+.room-progress small { display: flex; align-items: center; justify-content: space-between; color: #c8c0b2; font-size: 10px; }
+.room-progress small svg { width: 14px; color: #858b82; }
+.room-chat > div { min-height: 140px; margin-top: 14px; display: grid; align-content: start; gap: 10px; }
+.room-chat p { margin: 0; color: #d7cfc0; font-size: 10px; line-height: 1.45; }
+.room-chat form { min-height: 42px; padding: 0 6px 0 12px; border: 1px solid rgba(239,231,215,.16); border-radius: 8px; display: flex; align-items: center; }
+.room-chat input { min-width: 0; flex: 1; border: 0; outline: 0; color: #f2ecdf; background: transparent; font: 10px Manrope, sans-serif; }
+.room-chat button { width: 30px; height: 30px; border: 0; border-radius: 7px; color: #cfc8bb; background: transparent; cursor: pointer; }
+.room-chat button svg { width: 14px; }
