{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://shoditsa.ru/schemas/dtf-games-promo-pack.schema.json",
  "title": "Shoditsa DTF Games Promo Pack",
  "type": "object",
  "required": [
    "schemaVersion",
    "pack",
    "compatibility",
    "items"
  ],
  "properties": {
    "schemaVersion": {
      "const": 1
    },
    "pack": {
      "type": "object",
      "required": [
        "id",
        "title",
        "locale",
        "answerMode",
        "itemCount",
        "maxAttempts",
        "variantKey",
        "cluePolicy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "subtitle": {
          "type": "string"
        },
        "locale": {
          "const": "ru-RU"
        },
        "answerMode": {
          "const": "game"
        },
        "itemCount": {
          "const": 30
        },
        "maxAttempts": {
          "const": 10
        },
        "variantKey": {
          "type": "string",
          "minLength": 1
        },
        "recommendedOrder": {
          "type": "array",
          "minItems": 30,
          "maxItems": 30,
          "uniqueItems": true,
          "items": {
            "type": "string"
          }
        },
        "cluePolicy": {
          "type": "object",
          "required": [
            "openingHints",
            "unlockAfterAttempts",
            "transportField"
          ],
          "properties": {
            "openingHints": {
              "const": 2
            },
            "unlockAfterAttempts": {
              "const": [
                5,
                8,
                9
              ]
            },
            "transportField": {
              "const": "progressiveHints"
            }
          }
        }
      }
    },
    "compatibility": {
      "type": "object"
    },
    "items": {
      "type": "array",
      "minItems": 30,
      "maxItems": 30,
      "items": {
        "type": "object",
        "required": [
          "id",
          "answerType",
          "answerRef",
          "fallbackAnswerCard",
          "difficulty",
          "recognizability",
          "motifs",
          "progressiveHints",
          "result",
          "sources",
          "moderation"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^dtf-[a-z0-9-]+$"
          },
          "answerType": {
            "const": "game"
          },
          "difficulty": {
            "enum": [
              "easy",
              "medium",
              "hard"
            ]
          },
          "recognizability": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "answerRef": {
            "type": "object",
            "required": [
              "mode",
              "titleRu",
              "titleOriginal",
              "year",
              "steamAppIds",
              "aliases",
              "resolutionOrder"
            ],
            "properties": {
              "mode": {
                "const": "game"
              },
              "titleRu": {
                "type": "string",
                "minLength": 1
              },
              "titleOriginal": {
                "type": "string",
                "minLength": 1
              },
              "year": {
                "type": "integer",
                "minimum": 1950,
                "maximum": 2100
              },
              "legacyReleaseYears": {
                "type": "array",
                "items": {
                  "type": "integer"
                }
              },
              "steamAppIds": {
                "type": "array",
                "uniqueItems": true,
                "items": {
                  "type": "integer",
                  "minimum": 1
                }
              },
              "aliases": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "resolutionOrder": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "progressiveHints": {
            "type": "array",
            "minItems": 5,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": [
                "key",
                "unlockAfterAttempts",
                "type",
                "text",
                "strength",
                "spoilerRisk",
                "sourceKeys"
              ],
              "properties": {
                "key": {
                  "type": "string"
                },
                "unlockAfterAttempts": {
                  "enum": [
                    0,
                    5,
                    8,
                    9
                  ]
                },
                "type": {
                  "enum": [
                    "archetype_comment",
                    "satirical_context",
                    "community_meme",
                    "factual_rescue"
                  ]
                },
                "authorArchetype": {
                  "type": "string"
                },
                "text": {
                  "type": "string",
                  "minLength": 20
                },
                "strength": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                },
                "spoilerRisk": {
                  "enum": [
                    "low",
                    "medium",
                    "high"
                  ]
                },
                "sourceKeys": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "sources": {
            "type": "array",
            "minItems": 2
          },
          "moderation": {
            "type": "object",
            "required": [
              "allCommentTextAuthoredForGame",
              "directQuotesUsed",
              "realUsersReferenced",
              "manualReviewRequired"
            ]
          }
        }
      }
    }
  }
}
