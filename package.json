{
  "name": "seans",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "yandex:build": "npm run build",
    "yandex:pack": "node scripts/package-yandex-archive.mjs",
    "yandex:bundle": "npm run yandex:build && npm run yandex:pack",
    "preview": "vite preview",
    "deploy:quick": "powershell -ExecutionPolicy Bypass -File scripts/deploy-timeweb.ps1",
    "deploy:quick:skip-build": "powershell -ExecutionPolicy Bypass -File scripts/deploy-timeweb.ps1 -SkipBuild",
    "data:build": "tsx scripts/import-kinopoisk.ts",
    "data:build:navigator": "node scripts/import-kinopoisk-navigator.mjs",
    "data:build:anime": "node scripts/import-shikimori-animes.mjs",
    "data:build:anime:roles": "node scripts/import-shikimori-animes.mjs --fetch-roles",
    "data:build:games": "node scripts/import-thegamesdb-incremental.mjs --batch=20",
    "data:build:games:steam": "node scripts/import-steam-games.mjs",
    "data:build:games:all": "node scripts/import-steam-games.mjs --all",
    "data:build:games:top10": "node scripts/build-thegamesdb-top10.mjs",
    "data:build:games:incremental": "node scripts/import-thegamesdb-incremental.mjs",
    "data:build:games:backfill": "node scripts/backfill-missing-cards.mjs",
    "data:build:music:test": "node scripts/build-music-test-dataset.mjs",
    "data:refill": "node scripts/refill-missing-movies.mjs",
    "data:hints": "node scripts/enrich-movie-hints.mjs",
    "data:sanitize:movies": "node scripts/sanitize-movie-hints.mjs",
    "data:sanitize:movies:title-overlap": "node scripts/rewrite-movie-title-overlaps.mjs",
    "data:sanitize:series": "node scripts/sanitize-series-hints.mjs",
    "data:sanitize:series:title-overlap": "node scripts/rewrite-series-title-overlaps.mjs",
    "data:enrich:series-meta": "node scripts/enrich-series-seasons-status.mjs",
    "data:sanitize:games": "node scripts/sanitize-game-hints.mjs",
    "data:catalogs": "node scripts/build-library-json-structure.mjs",
    "data:download:library-images": "node scripts/download-library-images.mjs",
    "data:optimize:library-images": "node scripts/optimize-library-images.mjs",
    "data:relink:library-images": "node scripts/relink-library-images.mjs",
    "data:fix:people-anime-images": "node scripts/fix-people-and-anime-images.mjs",
    "data:dedupe:backdrops": "node scripts/dedupe-library-backdrops.mjs",
    "data:assets:prepare": "npm run data:download:library-images && npm run data:optimize:library-images && npm run data:relink:library-images && npm run data:fix:people-anime-images && npm run data:dedupe:backdrops",
    "deploy:library-assets": "powershell -ExecutionPolicy Bypass -File scripts/deploy-library-assets.ps1",
    "data:translate:games:ru": "node scripts/translate-game-hints-google.mjs",
    "data:collect-ids": "node scripts/collect-kinopoisk-ids.mjs",
    "data:enrich:music:first10": "node scripts/enrich-music-artists-first10.mjs --limit=10",
    "data:resolve:music": "node scripts/resolve-music-conflicts.mjs",
    "data:review:music:payload": "node scripts/build-music-factcheck-payload.mjs",
    "data:music:exclude-pending": "node scripts/exclude-music-pending-review.mjs",
    "data:music:include-pending": "node scripts/include-music-pending-review.mjs",
    "data:music:hints:payload": "node scripts/build-music-hints-payload.mjs",
    "data:music:hints:run": "node scripts/run-music-hints-openai.mjs",
    "data:music:hints:repair": "node scripts/repair-music-hints-failed.mjs",
    "data:music:hints:validate": "node scripts/validate-music-hints-output.mjs",
    "data:validate": "node scripts/validate-generated-data.mjs",
    "daily:salt": "node scripts/set-global-daily-salt.mjs",
    "metrics:baseline": "node scripts/collect-baseline-metrics.mjs",
    "smoke": "npm run build && npm run data:validate"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^0.468.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "archiver": "^7.0.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tsx": "latest"
  }
}
