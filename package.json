{
  "name": "seans",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:quick": "powershell -ExecutionPolicy Bypass -File scripts/deploy-timeweb.ps1",
    "deploy:quick:skip-build": "powershell -ExecutionPolicy Bypass -File scripts/deploy-timeweb.ps1 -SkipBuild",
    "data:build": "tsx scripts/import-kinopoisk.ts",
    "data:build:navigator": "node scripts/import-kinopoisk-navigator.mjs",
    "data:build:games": "node scripts/import-thegamesdb-incremental.mjs --batch=20",
    "data:build:games:steam": "node scripts/import-steam-games.mjs",
    "data:build:games:all": "node scripts/import-steam-games.mjs --all",
    "data:build:games:top10": "node scripts/build-thegamesdb-top10.mjs",
    "data:build:games:incremental": "node scripts/import-thegamesdb-incremental.mjs",
    "data:build:games:backfill": "node scripts/backfill-missing-cards.mjs",
    "data:refill": "node scripts/refill-missing-movies.mjs",
    "data:hints": "node scripts/enrich-movie-hints.mjs",
    "data:sanitize:movies": "node scripts/sanitize-movie-hints.mjs",
    "data:sanitize:movies:title-overlap": "node scripts/rewrite-movie-title-overlaps.mjs",
    "data:sanitize:series": "node scripts/sanitize-series-hints.mjs",
    "data:sanitize:series:title-overlap": "node scripts/rewrite-series-title-overlaps.mjs",
    "data:enrich:series-meta": "node scripts/enrich-series-seasons-status.mjs",
    "data:sanitize:games": "node scripts/sanitize-game-hints.mjs",
    "data:translate:games:ru": "node scripts/translate-game-hints-google.mjs",
    "data:collect-ids": "node scripts/collect-kinopoisk-ids.mjs",
    "data:validate": "node scripts/validate-generated-data.mjs",
    "metrics:baseline": "node scripts/collect-baseline-metrics.mjs",
    "smoke": "npm run build && npm run data:validate"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^0.468.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "playwright": "^1.61.1",
    "tsx": "latest"
  }
}
