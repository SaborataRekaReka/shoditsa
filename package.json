{
  "name": "seans",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "yandex:build": "npm run build",
    "yandex:pack": "node scripts/deploy/package-yandex-archive.mjs",
    "yandex:bundle": "npm run yandex:build && npm run yandex:pack",
    "preview": "vite preview",
    "clean:workspace": "powershell -ExecutionPolicy Bypass -File scripts/maintenance/clean-workspace.ps1",
    "deploy:quick": "powershell -ExecutionPolicy Bypass -File scripts/deploy/timeweb.ps1",
    "deploy:quick:skip-build": "powershell -ExecutionPolicy Bypass -File scripts/deploy/timeweb.ps1 -SkipBuild",
    "data:build": "tsx scripts/kinopoisk/import-top500-movies.ts",
    "data:build:navigator": "node scripts/kinopoisk/import-navigator.mjs",
    "data:build:anime": "node scripts/anime/import-shikimori.mjs",
    "data:build:anime:roles": "node scripts/anime/import-shikimori.mjs --fetch-roles",
    "data:build:games": "node scripts/games/import-thegamesdb-incremental.mjs --batch=20",
    "data:build:games:steam": "node scripts/games/import-steam.mjs",
    "data:build:games:all": "node scripts/games/import-steam.mjs --all",
    "data:build:games:top10": "node scripts/games/build-thegamesdb-top10.mjs",
    "data:build:games:incremental": "node scripts/games/import-thegamesdb-incremental.mjs",
    "data:build:games:backfill": "node scripts/games/backfill-missing-cards.mjs",
    "data:build:music:test": "node scripts/music/build-dataset.mjs",
    "data:agent:music": "node scripts/music/run-agent-cycle.mjs",
    "data:agent:music:run": "node scripts/enrichment-agent/run.mjs music run",
    "data:agent:music:discover": "node scripts/enrichment-agent/run.mjs music discover",
    "data:agent:music:plan": "node scripts/enrichment-agent/run.mjs music plan",
    "data:agent:music:status": "node scripts/enrichment-agent/run.mjs music status",
    "data:agent:music:publish": "node scripts/enrichment-agent/run.mjs music publish --source=data/enrichment-agent/music/discovery/discovered-candidates.json",
    "data:agent:test": "node --test scripts/enrichment-agent/core.test.mjs scripts/enrichment-agent/music-hint.test.mjs",
    "data:refill": "node scripts/movies/refill-missing.mjs",
    "data:hints": "node scripts/movies/enrich-hints.mjs",
    "data:sanitize:movies": "node scripts/movies/sanitize-hints.mjs",
    "data:sanitize:movies:title-overlap": "node scripts/movies/rewrite-title-overlaps.mjs",
    "data:sanitize:series": "node scripts/series/sanitize-hints.mjs",
    "data:sanitize:series:title-overlap": "node scripts/series/rewrite-title-overlaps.mjs",
    "data:enrich:series-meta": "node scripts/series/enrich-seasons-status.mjs",
    "data:sanitize:games": "node scripts/games/sanitize-hints.mjs",
    "data:catalogs": "node scripts/assets/build-library-structure.mjs",
    "data:download:library-images": "node scripts/assets/download-images.mjs",
    "data:optimize:library-images": "node scripts/assets/optimize-images.mjs",
    "data:relink:library-images": "node scripts/assets/relink-images.mjs",
    "data:fix:people-anime-images": "node scripts/assets/fix-people-anime-images.mjs",
    "data:dedupe:backdrops": "node scripts/assets/dedupe-backdrops.mjs",
    "data:assets:prepare": "npm run data:download:library-images && npm run data:optimize:library-images && npm run data:relink:library-images && npm run data:fix:people-anime-images && npm run data:dedupe:backdrops",
    "deploy:library-assets": "powershell -ExecutionPolicy Bypass -File scripts/deploy/library-assets.ps1",
    "data:translate:games:ru": "node scripts/games/translate-hints-google.mjs",
    "data:collect-ids": "npm run data:collect-ids:movies",
    "data:collect-ids:movies": "node scripts/kinopoisk/collect-ids.mjs --out=data/kinopoisk/navigator/movies/ids.json --state=data/kinopoisk/navigator/movies/state.json",
    "data:collect-ids:series": "node scripts/kinopoisk/collect-ids.mjs --out=data/kinopoisk/navigator/series/ids.json --state=data/kinopoisk/navigator/series/state.json",
    "data:enrich:music:first10": "node scripts/music/enrich-artists.mjs --limit=10",
    "data:resolve:music": "node scripts/music/resolve-conflicts.mjs",
    "data:review:music:payload": "node scripts/music/build-factcheck-payload.mjs",
    "data:music:exclude-pending": "node scripts/music/exclude-pending-review.mjs",
    "data:music:include-pending": "node scripts/music/include-pending-review.mjs",
    "data:music:hints:payload": "node scripts/music/build-hints-payload.mjs",
    "data:music:hints:run": "node scripts/music/run-hints-openai.mjs",
    "data:music:hints:repair": "node scripts/music/repair-hints.mjs",
    "data:music:hints:validate": "node scripts/music/validate-hints-output.mjs",
    "data:audit:music": "node scripts/music/audit-database.mjs",
    "data:validate": "node scripts/diagnostics/validate-generated-data.mjs",
    "daily:salt": "node scripts/maintenance/set-daily-salt.mjs",
    "metrics:baseline": "node scripts/diagnostics/collect-baseline-metrics.mjs",
    "smoke": "npm run build && npm run data:validate && npm run data:audit:music"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "lucide-react": "^0.468.0",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "archiver": "^7.0.1",
    "playwright": "^1.61.1",
    "sharp": "^0.35.3",
    "tsx": "latest"
  }
}
